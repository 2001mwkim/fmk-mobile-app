<?xml version="1.0" encoding="utf-8"?>
<!-- 2x2 챔피언십 순위 콤팩트: 킥커 + 타이틀 + Top 3(순위/팀바/이름/포인트).
     토글 없음 — Provider 가 마지막 선택(드라이버/팀)을 그대로 따른다. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root_standings_compact"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:paddingHorizontal="14dp"
    android:paddingVertical="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:includeFontPadding="false"
        android:letterSpacing="0.22"
        android:maxLines="1"
        android:text="VIA FORMULA"
        android:textColor="@color/fmk_faint"
        android:textSize="9sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_stc_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:fontFamily="sans-serif-black"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="챔피언십"
        android:textColor="@color/fmk_white"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/row_stc_1"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView android:id="@+id/tv_stc1_pos" android:layout_width="18dp" android:layout_height="wrap_content" android:fontFamily="sans-serif-black" android:gravity="center" android:includeFontPadding="false" android:textColor="@color/fmk_red" android:textSize="13sp" android:textStyle="bold|italic" />
            <ImageView android:id="@+id/iv_stc1_bar" android:layout_width="3dp" android:layout_height="match_parent" android:layout_marginVertical="5dp" android:scaleType="fitXY" android:src="@drawable/accent_bar" android:contentDescription="@null" />
            <TextView android:id="@+id/tv_stc1_name" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:ellipsize="end" android:fontFamily="sans-serif-medium" android:includeFontPadding="false" android:maxLines="1" android:textColor="@color/fmk_white" android:textSize="12sp" android:textStyle="bold" />
            <TextView android:id="@+id/tv_stc1_pts" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-medium" android:includeFontPadding="false" android:textColor="@color/fmk_text" android:textSize="12sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/row_stc_2"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView android:id="@+id/tv_stc2_pos" android:layout_width="18dp" android:layout_height="wrap_content" android:fontFamily="sans-serif-black" android:gravity="center" android:includeFontPadding="false" android:textColor="@color/fmk_dim" android:textSize="13sp" android:textStyle="bold|italic" />
            <ImageView android:id="@+id/iv_stc2_bar" android:layout_width="3dp" android:layout_height="match_parent" android:layout_marginVertical="5dp" android:scaleType="fitXY" android:src="@drawable/accent_bar" android:contentDescription="@null" />
            <TextView android:id="@+id/tv_stc2_name" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:ellipsize="end" android:fontFamily="sans-serif-medium" android:includeFontPadding="false" android:maxLines="1" android:textColor="@color/fmk_white" android:textSize="12sp" android:textStyle="bold" />
            <TextView android:id="@+id/tv_stc2_pts" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-medium" android:includeFontPadding="false" android:textColor="@color/fmk_text" android:textSize="12sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/row_stc_3"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView android:id="@+id/tv_stc3_pos" android:layout_width="18dp" android:layout_height="wrap_content" android:fontFamily="sans-serif-black" android:gravity="center" android:includeFontPadding="false" android:textColor="@color/fmk_dim" android:textSize="13sp" android:textStyle="bold|italic" />
            <ImageView android:id="@+id/iv_stc3_bar" android:layout_width="3dp" android:layout_height="match_parent" android:layout_marginVertical="5dp" android:scaleType="fitXY" android:src="@drawable/accent_bar" android:contentDescription="@null" />
            <TextView android:id="@+id/tv_stc3_name" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:ellipsize="end" android:fontFamily="sans-serif-medium" android:includeFontPadding="false" android:maxLines="1" android:textColor="@color/fmk_white" android:textSize="12sp" android:textStyle="bold" />
            <TextView android:id="@+id/tv_stc3_pts" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-medium" android:includeFontPadding="false" android:textColor="@color/fmk_text" android:textSize="12sp" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
