<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root_live"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="13dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_live_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="9dp"
            android:background="@drawable/live_badge_bg"
            android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="7dp"
            android:paddingVertical="3dp"
            android:textColor="@color/fmk_white"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_gp_name_live"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:textColor="@color/fmk_white"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_lap_cur"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/fmk_white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_lap_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:fontFamily="sans-serif"
            android:textColor="@color/fmk_faint"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:fontFamily="sans-serif-medium"
            android:text="LAP"
            android:textColor="@color/fmk_dim"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/pb_lap"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="11dp"
        android:progressDrawable="@drawable/progress_lap" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="13dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/card_p1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="9dp"
            android:layout_weight="1"
            android:background="@drawable/card_top_p1"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="11dp">
            <TextView android:id="@+id/tv_p1_pos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="7dp" android:fontFamily="sans-serif-medium" android:text="1" android:textColor="@color/fmk_red" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/tv_p1_code" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-medium" android:maxLines="1" android:textColor="@color/fmk_white" android:textSize="21sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_p2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="9dp"
            android:layout_weight="1"
            android:background="@drawable/card_top_p2"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="11dp">
            <TextView android:id="@+id/tv_p2_pos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="7dp" android:fontFamily="sans-serif-medium" android:text="2" android:textColor="@color/fmk_dim" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/tv_p2_code" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-medium" android:maxLines="1" android:textColor="@color/fmk_text" android:textSize="21sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_p3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/card_top_p3"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="11dp">
            <TextView android:id="@+id/tv_p3_pos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="7dp" android:fontFamily="sans-serif-medium" android:text="3" android:textColor="@color/fmk_dim" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/tv_p3_code" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-medium" android:maxLines="1" android:textColor="@color/fmk_text" android:textSize="21sp" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
