<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root_default"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <ImageView
            android:layout_width="3dp"
            android:layout_height="16dp"
            android:layout_marginEnd="8dp"
            android:background="@color/fmk_red"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/tv_gp_flag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:textColor="@color/fmk_white"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tv_gp_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:textColor="@color/fmk_white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:text="KST"
            android:textColor="@color/fmk_faint"
            android:textSize="11sp" />

        <LinearLayout
            android:id="@+id/toggle_group_default"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/widget_toggle_bg"
            android:orientation="horizontal"
            android:padding="2dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/btn_toggle_schedule_default"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_toggle_active_bg"
                android:fontFamily="sans-serif-medium"
                android:includeFontPadding="false"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="일정"
                android:textColor="@color/fmk_white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_toggle_live_default"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:includeFontPadding="false"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="결과"
                android:textColor="@color/fmk_dim"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <include layout="@layout/widget_fmk_session_row_1" />
        <include layout="@layout/widget_fmk_session_row_2" />
        <include layout="@layout/widget_fmk_session_row_3" />
        <include layout="@layout/widget_fmk_session_row_4" />
        <include layout="@layout/widget_fmk_session_row_5" />
    </LinearLayout>
</LinearLayout>
