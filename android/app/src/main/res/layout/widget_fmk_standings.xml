<?xml version="1.0" encoding="utf-8"?>
<!-- 4x2 챔피언십 순위 위젯: 헤더(브랜드 바 + 타이틀 + 드라이버/팀 토글) /
     헤어라인 / 순위 5행. 순위 탭과 같은 데이터·표기(▲▼ 변동). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root_standings"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="3dp"
            android:layout_height="16dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/accent_bar"
            android:scaleType="fitXY"
            android:tint="@color/fmk_red"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="sans-serif-black"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="챔피언십"
            android:textColor="@color/fmk_white"
            android:textSize="18sp" />

        <LinearLayout
            android:id="@+id/toggle_group_standings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/widget_toggle_bg"
            android:orientation="horizontal"
            android:padding="2dp">

            <TextView
                android:id="@+id/btn_st_drivers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_toggle_active_bg"
                android:fontFamily="sans-serif-medium"
                android:includeFontPadding="false"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="드라이버"
                android:textColor="@color/fmk_white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_st_teams"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:includeFontPadding="false"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="팀"
                android:textColor="@color/fmk_dim"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="9dp"
        android:layout_marginBottom="5dp"
        android:background="@color/fmk_divider"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <include layout="@layout/widget_fmk_standings_row_1" />
        <include layout="@layout/widget_fmk_standings_row_2" />
        <include layout="@layout/widget_fmk_standings_row_3" />
        <include layout="@layout/widget_fmk_standings_row_4" />
        <include layout="@layout/widget_fmk_standings_row_5" />
    </LinearLayout>
</LinearLayout>
