<?xml version="1.0" encoding="utf-8"?>
<!-- 순위 위젯 행 2/5: 순위 | 팀컬러 바 | 이름 | 변동(▲▼) | 포인트.
     변동/팀컬러는 Provider 가 동적으로 색을 입힌다. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/row_st_2"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:gravity="center_vertical"
    android:orientation="horizontal">
    <TextView android:id="@+id/tv_st2_pos" android:layout_width="22dp" android:layout_height="wrap_content" android:fontFamily="sans-serif-black" android:gravity="center" android:includeFontPadding="false" android:textColor="@color/fmk_dim" android:textSize="14sp" android:textStyle="bold|italic" />
    <ImageView android:id="@+id/iv_st2_bar" android:layout_width="3dp" android:layout_height="match_parent" android:layout_marginVertical="5dp" android:layout_marginStart="2dp" android:scaleType="fitXY" android:src="@drawable/accent_bar" android:contentDescription="@null" />
    <TextView android:id="@+id/tv_st2_name" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="10dp" android:ellipsize="end" android:fontFamily="sans-serif-medium" android:includeFontPadding="false" android:maxLines="1" android:textColor="@color/fmk_white" android:textSize="13sp" android:textStyle="bold" />
    <TextView android:id="@+id/tv_st2_change" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="10dp" android:fontFamily="sans-serif-medium" android:includeFontPadding="false" android:textColor="@color/fmk_dim" android:textSize="10sp" android:textStyle="bold" />
    <TextView android:id="@+id/tv_st2_pts" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-medium" android:gravity="end" android:includeFontPadding="false" android:textColor="@color/fmk_white" android:textSize="13sp" android:textStyle="bold" />
</LinearLayout>
