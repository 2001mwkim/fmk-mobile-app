<?xml version="1.0" encoding="utf-8"?>
<!-- 2x2 콤팩트 화면. 하나의 스켈레톤을 모드별로 다르게 바인딩한다.
     · 일정: VIA FORMULA 킥커 / GP명 / 다음 세션명(레드) / 시간(대형) / 날짜
     · 라이브·결과: LIVE·결과 뱃지 / GP명 / P1(레드) / 드라이버명(대형) / 랩·기록
     공간이 좁아 토글은 없다 — 탭하면 앱이 열린다. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root_compact"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:paddingHorizontal="14dp"
    android:paddingVertical="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_c_kicker"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:includeFontPadding="false"
            android:letterSpacing="0.22"
            android:maxLines="1"
            android:text="VIA FORMULA"
            android:textColor="@color/fmk_faint"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_c_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/live_badge_bg"
            android:fontFamily="sans-serif-medium"
            android:includeFontPadding="false"
            android:letterSpacing="0.08"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:textColor="@color/fmk_white"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_c_gp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:fontFamily="sans-serif-black"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:textColor="@color/fmk_white"
        android:textSize="15sp" />

    <!-- 스페이서: 본문을 아래로 밀어 시간/이름이 시각적 중심이 되게 한다 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/tv_c_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:textColor="@color/fmk_red"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_c_big"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:fontFamily="sans-serif-black"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:textColor="@color/fmk_white"
        android:textSize="27sp" />

    <TextView
        android:id="@+id/tv_c_sub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:ellipsize="end"
        android:fontFamily="sans-serif"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:textColor="@color/fmk_dim"
        android:textSize="11sp" />
</LinearLayout>
