<?xml version="1.0" encoding="utf-8"?>
<!-- 위젯 일정 행 4/5. 좌측 도트는 '다음 세션' 하이라이트용(기본 invisible 로
     자리를 차지해 행 들여쓰기를 통일). 색은 Provider 가 동적으로 바꾼다. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/row_s4"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:gravity="center_vertical"
    android:orientation="horizontal">
    <ImageView android:id="@+id/iv_s4_dot" android:layout_width="5dp" android:layout_height="5dp" android:layout_marginEnd="8dp" android:background="@drawable/dot_red" android:visibility="invisible" android:contentDescription="@null" />
    <TextView android:id="@+id/tv_s4_name" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:ellipsize="end" android:fontFamily="sans-serif" android:includeFontPadding="false" android:maxLines="1" android:textColor="@color/fmk_text" android:textSize="13sp" />
    <TextView android:id="@+id/tv_s4_date" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="12dp" android:fontFamily="sans-serif" android:gravity="end" android:includeFontPadding="false" android:textColor="@color/fmk_dim" android:textSize="11sp" />
    <TextView android:id="@+id/tv_s4_time" android:layout_width="52dp" android:layout_height="wrap_content" android:fontFamily="sans-serif-medium" android:gravity="end" android:includeFontPadding="false" android:textColor="@color/fmk_white" android:textSize="14sp" android:textStyle="bold" />
</LinearLayout>
